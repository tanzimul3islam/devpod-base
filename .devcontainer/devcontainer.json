{
  "build": {
    "context": "..",
    "dockerfile": "Dockerfile",
    "args": {
      "USERNAME": "tanzimul"
    }
  },
  "remoteUser": "tanzimul",
  "containerUser": "root",
  "postCreateCommand": "scripts/setup",
  "features": {
    "ghcr.io/devcontainers/features/nix:1": {
      "version": "latest",
      "multiUser": true
    },
    "ghcr.io/devcontainers/features/azure-cli:1": {
      "version": "latest",
      "installBicep": false
    }
  }
}
