{
  "build": {
    "context": "..",
    "dockerfile": "Dockerfile",
    "args": { "USERNAME": "tanzimul" }
  },
  "remoteUser": "tanzimul",
  "containerUser": "root",
  "postCreateCommand": "scripts/setup",
  "features": {
    "ghcr.io/devcontainers/features/nix:1": { "version": "latest", "multiUser": true },
    "ghcr.io/devcontainers/features/azure-cli:1": { "version": "latest" },
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1.3.1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": true
    }
  }
}
